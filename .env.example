# Lapstream — environment variables (all optional for Phase 1).
# Copy to .env.local and fill in only what you need.

# Your deployed site URL — used for canonical links, sitemap, robots and OG tags.
NEXT_PUBLIC_SITE_URL=https://lapstream.netlify.app

# Base URLs for the free community APIs (defaults are baked in; override only if needed).
NEXT_PUBLIC_JOLPICA_BASE=https://api.jolpi.ca/ergast/f1
NEXT_PUBLIC_OPENF1_BASE=https://api.openf1.org/v1

# --- Phase 2+ (not needed yet) ---
# YouTube Data API key (free quota) for the video grid:
# YOUTUBE_API_KEY=
# YOUTUBE_CHANNEL_ID=

# Supabase (only when you add the GitHub Actions cron pipeline):
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
